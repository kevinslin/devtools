#!/usr/bin/env python3
"""Convert an epoch timestamp into UTC, local, and relative time."""

from __future__ import annotations

import argparse
from datetime import datetime, timezone
from decimal import Decimal, InvalidOperation
import os
import sys
import time


MILLISECONDS_THRESHOLD = Decimal("100000000000")
NOW_OVERRIDE_ENV = "TOOL_EPOCH_NOW"


class EpochError(Exception):
    """Raised when epoch input cannot be converted."""


def _parse_epoch(raw: str) -> Decimal:
    try:
        timestamp = Decimal(raw.strip().replace("_", ""))
    except InvalidOperation as exc:
        raise EpochError(f"invalid epoch timestamp {raw!r}") from exc

    if not timestamp.is_finite():
        raise EpochError(f"invalid epoch timestamp {raw!r}")

    if abs(timestamp) >= MILLISECONDS_THRESHOLD:
        return timestamp / Decimal("1000")
    return timestamp


def _datetime_from_epoch_seconds(seconds: Decimal) -> datetime:
    try:
        return datetime.fromtimestamp(float(seconds), tz=timezone.utc)
    except (OverflowError, OSError, ValueError) as exc:
        raise EpochError(f"epoch timestamp is out of range: {seconds}") from exc


def _current_time() -> datetime:
    override = os.environ.get(NOW_OVERRIDE_ENV)
    if override:
        return _datetime_from_epoch_seconds(_parse_epoch(override))
    return datetime.now(timezone.utc)


def _format_datetime(value: datetime) -> str:
    display = value.replace(microsecond=(value.microsecond // 1000) * 1000)
    milliseconds = f"{display.microsecond // 1000:03d}"
    return (
        display.strftime("%A, %B %-d, %Y at %-I:%M:%S.")
        + milliseconds
        + display.strftime(" %p")
    )


def _format_gmt_offset(value: datetime) -> str:
    offset = value.strftime("%z")
    if not offset:
        return "GMT"
    return f"GMT{offset[:3]}:{offset[3:]}"


def _format_local_datetime(value: datetime) -> str:
    local_value = value.astimezone()
    suffix = _format_gmt_offset(local_value)
    if time.localtime(value.timestamp()).tm_isdst > 0:
        suffix = f"{suffix} DST"
    return f"{_format_datetime(local_value)} {suffix}"


def _plural(count: int, unit: str) -> str:
    if count == 1:
        return f"1 {unit}"
    return f"{count} {unit}s"


def _relative_unit(seconds: int) -> tuple[int, str]:
    units = [
        (365 * 24 * 60 * 60, "year"),
        (30 * 24 * 60 * 60, "month"),
        (7 * 24 * 60 * 60, "week"),
        (24 * 60 * 60, "day"),
        (60 * 60, "hour"),
        (60, "minute"),
        (1, "second"),
    ]
    for unit_seconds, unit_name in units:
        if seconds >= unit_seconds:
            return seconds // unit_seconds, unit_name
    return 0, "second"


def _format_relative(value: datetime, *, now: datetime) -> str:
    delta_seconds = int((now - value).total_seconds())
    if delta_seconds == 0:
        return "now"

    count, unit = _relative_unit(abs(delta_seconds))
    text = _plural(count, unit)
    if delta_seconds > 0:
        return f"{text} ago"
    return f"in {text}"


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Convert an epoch timestamp into UTC, local, and relative time."
    )
    parser.add_argument(
        "timestamp",
        help="epoch timestamp in seconds or milliseconds, with optional decimals",
    )
    return parser


def main(argv: list[str] | None = None) -> int:
    if hasattr(time, "tzset"):
        time.tzset()

    parser = _build_parser()
    args = parser.parse_args(argv)

    try:
        value = _datetime_from_epoch_seconds(_parse_epoch(args.timestamp))
        now = _current_time()
    except EpochError as exc:
        print(f"epoch: {exc}", file=sys.stderr)
        return 1

    print(f"UTC: {_format_datetime(value)}")
    print(f"Local: {_format_local_datetime(value)}")
    print(f"Relative: {_format_relative(value, now=now)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
