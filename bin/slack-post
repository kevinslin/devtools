#!/usr/bin/env python3
"""Post a plain-text message to Slack.

Usage:
  slack-post --channel C123 --token "$SLACK_TOKEN" "hello"
  printf 'hello\n' | slack-post --channel C123
"""

from __future__ import annotations

import argparse
import json
import os
import sys
from typing import Any
from urllib import error, request


DEFAULT_API_URL = "https://slack.com/api/chat.postMessage"


class SlackPostError(Exception):
    """Raised when request setup or Slack posting fails."""


def _parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Post a plain-text message to a Slack channel."
    )
    parser.add_argument(
        "-c",
        "--channel",
        required=True,
        help="Slack channel ID or name to post into.",
    )
    parser.add_argument(
        "-t",
        "--token",
        help="Slack bot/user token. Defaults to SLACK_TOKEN or SLACK_BOT_TOKEN.",
    )
    parser.add_argument(
        "--thread-ts",
        help="Optional Slack thread timestamp to reply in a thread.",
    )
    parser.add_argument(
        "--api-url",
        default=DEFAULT_API_URL,
        help=argparse.SUPPRESS,
    )
    parser.add_argument(
        "--timeout",
        type=float,
        default=15.0,
        help="Request timeout in seconds. Default: 15.",
    )
    parser.add_argument(
        "message",
        nargs="*",
        help="Message text. If omitted, slack-post reads stdin.",
    )
    return parser.parse_args()


def _resolve_token(args: argparse.Namespace) -> str:
    token = args.token or os.environ.get("SLACK_TOKEN") or os.environ.get("SLACK_BOT_TOKEN")
    if not token or not token.strip():
        raise SlackPostError("provide a token with --token, SLACK_TOKEN, or SLACK_BOT_TOKEN")
    return token.strip()


def _resolve_text(args: argparse.Namespace) -> str:
    if args.message:
        text = " ".join(args.message)
    else:
        if sys.stdin.isatty():
            raise SlackPostError("provide a message argument or pipe message text on stdin")
        try:
            text = sys.stdin.read()
        except OSError as exc:
            raise SlackPostError(f"failed to read stdin: {exc}") from exc
        text = text.rstrip("\n")

    if not text.strip():
        raise SlackPostError("message text must not be empty")
    return text


def _decode_response(raw: bytes) -> dict[str, Any]:
    try:
        payload = json.loads(raw.decode("utf-8"))
    except (UnicodeDecodeError, json.JSONDecodeError) as exc:
        raise SlackPostError(f"Slack API returned non-JSON response: {exc}") from exc
    if not isinstance(payload, dict):
        raise SlackPostError("Slack API returned a non-object JSON response")
    return payload


def _post_message(
    *,
    api_url: str,
    token: str,
    channel: str,
    text: str,
    thread_ts: str | None,
    timeout: float,
) -> dict[str, Any]:
    payload: dict[str, Any] = {
        "channel": channel,
        "text": text,
    }
    if thread_ts:
        payload["thread_ts"] = thread_ts

    body = json.dumps(payload).encode("utf-8")
    slack_request = request.Request(
        api_url,
        data=body,
        method="POST",
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json; charset=utf-8",
            "User-Agent": "slack-post/1.0",
        },
    )

    try:
        with request.urlopen(slack_request, timeout=timeout) as response:
            response_payload = _decode_response(response.read())
    except error.HTTPError as exc:
        try:
            response_payload = _decode_response(exc.read())
        except SlackPostError:
            raise SlackPostError(f"Slack API HTTP {exc.code}") from exc
        slack_error = response_payload.get("error", "unknown_error")
        raise SlackPostError(f"Slack API HTTP {exc.code}: {slack_error}") from exc
    except error.URLError as exc:
        raise SlackPostError(f"failed to reach Slack API: {exc.reason}") from exc
    except TimeoutError as exc:
        raise SlackPostError("Slack API request timed out") from exc

    if response_payload.get("ok") is not True:
        slack_error = response_payload.get("error", "unknown_error")
        raise SlackPostError(f"Slack API error: {slack_error}")

    return response_payload


def main() -> int:
    args = _parse_args()

    try:
        channel = args.channel.strip()
        if not channel:
            raise SlackPostError("channel must not be empty")
        response_payload = _post_message(
            api_url=args.api_url,
            token=_resolve_token(args),
            channel=channel,
            text=_resolve_text(args),
            thread_ts=args.thread_ts,
            timeout=args.timeout,
        )
    except SlackPostError as exc:
        print(f"slack-post: {exc}", file=sys.stderr)
        return 1

    ts = response_payload.get("ts")
    if isinstance(ts, str) and ts:
        print(f"posted message to {channel} at {ts}")
    else:
        print(f"posted message to {channel}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
