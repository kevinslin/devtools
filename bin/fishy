#!/usr/bin/env python3
"""Serve Mermaid diagrams from stdin in a local browser.

Usage:
  fishy [path] [--source-file FILE] [--host HOST] [--port PORT] [--title TITLE] [--no-open]
"""

from __future__ import annotations

import argparse
from dataclasses import dataclass
from functools import partial
import html
from http import HTTPStatus
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
import re
import sys
import webbrowser


DEFAULT_HOST = "127.0.0.1"
DEFAULT_PORT = 0
DEFAULT_TITLE = "Fishy Mermaid Preview"
MERMAID_MODULE_URL = "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs"
FENCED_BLOCK_RE = re.compile(r"^[ \t]{0,3}(?P<fence>`{3,}|~{3,})(?P<info>.*)$")
ATX_HEADING_RE = re.compile(r"^[ \t]{0,3}#{1,6}(?:[ \t]+|$)(?P<title>.*)$")


@dataclass(frozen=True)
class MermaidDiagram:
    title: str
    source: str


@dataclass(frozen=True)
class PreviewPayload:
    diagrams: list[MermaidDiagram]
    source: str
    source_version: str
    caption: str


DIAGRAM_SECTION_TEMPLATE = """      <section class="panel diagram" data-diagram-index="{index}">
        <div class="diagram-heading">
          <p class="eyebrow">diagram {index}</p>
          <h2>{title}</h2>
        </div>
        <div class="diagram-toolbar">
          <div class="diagram-toolbar-group">
            <span>View</span>
            <strong class="diagram-zoom-label">100%</strong>
          </div>
          <div class="diagram-toolbar-group">
            <button type="button" class="diagram-fit-button">Fit width</button>
            <button type="button" class="diagram-zoom-out-button">-</button>
            <button type="button" class="diagram-zoom-in-button">+</button>
          </div>
        </div>
        <div class="diagram-viewport">
          <div class="diagram-stage-wrap">
            <div class="diagram-stage">
              <pre class="mermaid">{diagram}</pre>
            </div>
          </div>
        </div>
        <details class="source-details">
          <summary>Source</summary>
          <pre class="source">{diagram}</pre>
        </details>
      </section>"""


