    }}

    .hero p {{
      margin: 0;
    }}

    .eyebrow {{
      color: var(--accent);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }}

    h1 {{
      margin: 0.55rem 0 0.4rem;
      font-size: clamp(2rem, 4vw, 3.4rem);
      line-height: 0.95;
    }}

    .caption {{
      color: var(--muted);
      max-width: 52rem;
    }}

    .diagram {{
      width: 100%;
      min-width: 0;
      padding: 0.75rem;
      display: grid;
      gap: 0.75rem;
    }}

    .diagram-toolbar {{
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      padding: 0.25rem 0.1rem 0;
      color: var(--muted);
      font-size: 0.92rem;
    }}

    .diagram-toolbar-group {{
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      flex-wrap: wrap;
    }}

    .diagram-toolbar button {{
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.86);
      color: var(--ink);
      border-radius: 999px;
      padding: 0.42rem 0.72rem;
      font: inherit;
      cursor: pointer;
      transition: background 120ms ease, transform 120ms ease, border-color 120ms ease;
    }}

    .diagram-toolbar button:hover {{
      background: rgba(13, 138, 168, 0.14);
      border-color: rgba(13, 138, 168, 0.28);
      transform: translateY(-1px);
    }}

    .diagram-zoom-label {{
      min-width: 4rem;
      text-align: center;
      font-variant-numeric: tabular-nums;
      color: var(--ink);
      font-weight: 600;
    }}

    .diagram-viewport {{
      position: relative;
      overflow: auto;
      height: min(78vh, 56rem);
      min-height: 28rem;
      padding: 1rem;
      border-radius: 20px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(240, 249, 252, 0.88)),
        linear-gradient(90deg, rgba(16, 50, 74, 0.05) 1px, transparent 1px),
        linear-gradient(rgba(16, 50, 74, 0.05) 1px, transparent 1px);
      background-size: auto, 24px 24px, 24px 24px;
      border: 1px solid rgba(16, 50, 74, 0.08);
      cursor: grab;
      overscroll-behavior: contain;
      touch-action: none;
      user-select: none;
    }}

    .diagram-viewport.is-panning {{
      cursor: grabbing;
    }}

    .diagram-viewport.is-panning * {{
      cursor: grabbing !important;
    }}

    .diagram-stage-wrap {{
      min-width: 100%;
      min-height: 100%;
      width: max-content;
      display: flex;
      align-items: flex-start;
      justify-content: center;
    }}

    .diagram-stage {{
      position: relative;
      flex: 0 0 auto;
      margin: 0;
    }}

    .diagram .mermaid {{
      min-width: 0;
      margin: 0;
      padding: 0;
      border-radius: 0;
      background: transparent;
    }}

    .diagram .mermaid svg {{
      display: block;
      transform-origin: top left;
    }}

    .note-hover-tooltip {{
      position: fixed;
      z-index: 30;
      max-width: min(34rem, calc(100vw - 1.5rem));
      padding: 0.75rem 0.9rem;
      border-radius: 14px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      background: rgba(16, 50, 74, 0.94);
      color: #f7fbff;
      box-shadow: 0 16px 36px rgba(8, 29, 42, 0.25);
      font-size: 0.95rem;
      line-height: 1.4;
      pointer-events: none;
      white-space: normal;
      word-break: break-word;
      opacity: 0;
      transform: translateY(6px);
      transition: opacity 120ms ease, transform 120ms ease;
    }}

    .note-hover-tooltip[data-visible="true"] {{
      opacity: 1;
      transform: translateY(0);
