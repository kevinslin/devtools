  </style>
</head>
<body>
  <main>
    <section class="panel hero">
      <p class="eyebrow">fishy</p>
      <h1>{title}</h1>
      <p class="caption">{caption}</p>
      <p class="caption"><a href="/source.mmd">download source</a></p>
    </section>
    <div class="diagram-list">
{diagrams}
    </div>
  </main>
  <div class="note-hover-tooltip" id="note-hover-tooltip" hidden></div>
  <script type="module">
    import mermaid from "{mermaid_url}";

    mermaid.initialize({{
      startOnLoad: false,
      sequence: {{
        useMaxWidth: false,
      }},
      flowchart: {{
        useMaxWidth: false,
      }},
      securityLevel: "strict",
      theme: "neutral",
    }});

    const tooltip = document.getElementById("note-hover-tooltip");
    const ZOOM_STEP = 0.15;
    const DOUBLE_CLICK_ZOOM = 1.5;
    const MIN_SCALE = 0.05;
    const MAX_SCALE = 3;
    const SOURCE_VERSION = "{source_version}";

    function getNoteLabel(noteTextNode) {{
      const tspans = Array.from(noteTextNode.querySelectorAll("tspan"))
        .map((node) => (node.textContent || "").trim())
        .filter(Boolean);
      if (tspans.length > 0) {{
        return tspans.join(" ");
      }}
      return (noteTextNode.textContent || "").trim();
    }}

    function positionTooltip(anchorRect) {{
      if (tooltip.hidden) {{
        return;
      }}

      const margin = 12;
      const tooltipRect = tooltip.getBoundingClientRect();
      let left = anchorRect.left + (anchorRect.width / 2) - (tooltipRect.width / 2);
      left = Math.max(margin, Math.min(left, window.innerWidth - tooltipRect.width - margin));

      let top = anchorRect.top - tooltipRect.height - margin;
      if (top < margin) {{
        top = Math.min(anchorRect.bottom + margin, window.innerHeight - tooltipRect.height - margin);
      }}

      tooltip.style.left = `${{left}}px`;
      tooltip.style.top = `${{Math.max(margin, top)}}px`;
    }}

    function showTooltip(label, anchorRect) {{
      tooltip.textContent = label;
      tooltip.hidden = false;
      tooltip.dataset.visible = "true";
      positionTooltip(anchorRect);
    }}

    function hideTooltip() {{
      tooltip.hidden = true;
      delete tooltip.dataset.visible;
    }}

    function attachNoteHover(textNode) {{
      const label = getNoteLabel(textNode);
      if (!label) {{
        return;
      }}

      const group = textNode.closest("g");
      if (group && !group.querySelector("title")) {{
        const title = document.createElementNS("http://www.w3.org/2000/svg", "title");
        title.textContent = label;
        group.prepend(title);
      }}

      const hoverTargets = [textNode];
      const noteBox = group ? group.querySelector("rect.note") : null;
      if (noteBox) {{
        hoverTargets.push(noteBox);
      }}

      for (const target of hoverTargets) {{
        target.style.cursor = "help";
        target.addEventListener("mouseenter", () => showTooltip(label, target.getBoundingClientRect()));
        target.addEventListener("mousemove", () => showTooltip(label, target.getBoundingClientRect()));
        target.addEventListener("mouseleave", hideTooltip);
      }}
    }}

    function installNoteHoverTooltips(root = document) {{
      for (const textNode of root.querySelectorAll("svg .noteText")) {{
        attachNoteHover(textNode);
      }}
    }}

    function setZoomLabel(context, scale) {{
      context.zoomLabel.textContent = `${{Math.round(scale * 100)}}%`;
    }}

    function readDiagramMetrics(svg) {{
      const viewBox = svg.viewBox?.baseVal;
      if (viewBox && viewBox.width > 0 && viewBox.height > 0) {{
        return {{
          width: viewBox.width,
          height: viewBox.height,
        }};
      }}

      const bbox = svg.getBBox();
      return {{
        width: Math.max(1, bbox.width),
        height: Math.max(1, bbox.height),
      }};
    }}

    function clampScale(scale) {{
      return Math.max(MIN_SCALE, Math.min(scale, MAX_SCALE));
    }}

    function getViewportPadding(viewport) {{
      const style = window.getComputedStyle(viewport);
      return {{
        x: (Number.parseFloat(style.paddingLeft) || 0) + (Number.parseFloat(style.paddingRight) || 0),
        y: (Number.parseFloat(style.paddingTop) || 0) + (Number.parseFloat(style.paddingBottom) || 0),
      }};
    }}

    function applyScale(context, scale) {{
      const svg = context.mermaidRoot.querySelector("svg");
      if (!svg || !context.diagramMetrics) {{
        return;
      }}

      context.currentScale = clampScale(scale);
      svg.style.width = `${{context.diagramMetrics.width * context.currentScale}}px`;
      svg.style.height = `${{context.diagramMetrics.height * context.currentScale}}px`;
      svg.style.maxWidth = "none";
      svg.style.transform = "none";
      context.stage.style.width = `${{context.diagramMetrics.width * context.currentScale}}px`;
      context.stage.style.height = `${{context.diagramMetrics.height * context.currentScale}}px`;
      context.stage.dataset.scale = context.currentScale.toFixed(4);
      setZoomLabel(context, context.currentScale);
    }}

    function fitDiagram(context) {{
      if (!context.diagramMetrics) {{
        return;
      }}

      const padding = getViewportPadding(context.viewport);
      const availableWidth = Math.max(1, context.viewport.clientWidth - padding.x);
      context.fitScale = clampScale(availableWidth / context.diagramMetrics.width);
      applyScale(context, context.fitScale);
      context.viewport.scrollTop = 0;
      context.viewport.scrollLeft = 0;
    }}

    function getViewportCenterPoint(viewport) {{
      const rect = viewport.getBoundingClientRect();
      return {{
        x: rect.left + (rect.width / 2),
        y: rect.top + (rect.height / 2),
      }};
    }}

    function zoomAt(context, scale, clientX, clientY) {{
      const svg = context.mermaidRoot.querySelector("svg");
      if (!svg || !context.diagramMetrics) {{
        return;
      }}

      const nextScale = clampScale(scale);
      if (Math.abs(nextScale - context.currentScale) < 0.0001) {{
        return;
      }}

      const beforeRect = context.stage.getBoundingClientRect();
      const focusX = (clientX - beforeRect.left) / context.currentScale;
      const focusY = (clientY - beforeRect.top) / context.currentScale;
      applyScale(context, nextScale);
      const afterRect = context.stage.getBoundingClientRect();
      context.viewport.scrollLeft += (afterRect.left + (focusX * context.currentScale)) - clientX;
      context.viewport.scrollTop += (afterRect.top + (focusY * context.currentScale)) - clientY;
    }}

    function zoomBy(context, delta) {{
      const point = getViewportCenterPoint(context.viewport);
      zoomAt(context, context.currentScale + delta, point.x, point.y);
    }}

    function endPan(context, event) {{
      if (!context.activePan || context.activePan.pointerId !== event.pointerId) {{
        return;
      }}

      if (context.viewport.hasPointerCapture(event.pointerId)) {{
        context.viewport.releasePointerCapture(event.pointerId);
      }}
      context.activePan = null;
      context.viewport.classList.remove("is-panning");
    }}

    function installDiagramPointerControls(context) {{
      context.viewport.addEventListener("pointerdown", (event) => {{
        if (event.button !== 0) {{
          return;
        }}

        context.activePan = {{
          pointerId: event.pointerId,
          startX: event.clientX,
          startY: event.clientY,
          scrollLeft: context.viewport.scrollLeft,
          scrollTop: context.viewport.scrollTop,
        }};
        context.viewport.classList.add("is-panning");
        context.viewport.setPointerCapture(event.pointerId);
      }});

      context.viewport.addEventListener("pointermove", (event) => {{
        if (!context.activePan || context.activePan.pointerId !== event.pointerId) {{
          return;
        }}

        context.viewport.scrollLeft = context.activePan.scrollLeft - (event.clientX - context.activePan.startX);
        context.viewport.scrollTop = context.activePan.scrollTop - (event.clientY - context.activePan.startY);
        hideTooltip();
        event.preventDefault();
      }});

      context.viewport.addEventListener("pointerup", (event) => endPan(context, event));
      context.viewport.addEventListener("pointercancel", (event) => endPan(context, event));
      context.viewport.addEventListener("lostpointercapture", (event) => endPan(context, event));
      context.viewport.addEventListener("dblclick", (event) => {{
        event.preventDefault();
        const nextScale = (event.altKey || event.shiftKey)
          ? context.currentScale / DOUBLE_CLICK_ZOOM
          : context.currentScale * DOUBLE_CLICK_ZOOM;
        zoomAt(context, nextScale, event.clientX, event.clientY);
      }});
    }}

    function installDiagramControls(diagram) {{
      const context = {{
        viewport: diagram.querySelector(".diagram-viewport"),
        stage: diagram.querySelector(".diagram-stage"),
        zoomLabel: diagram.querySelector(".diagram-zoom-label"),
        fitButton: diagram.querySelector(".diagram-fit-button"),
        zoomOutButton: diagram.querySelector(".diagram-zoom-out-button"),
        zoomInButton: diagram.querySelector(".diagram-zoom-in-button"),
        mermaidRoot: diagram.querySelector(".mermaid"),
        diagramMetrics: null,
        fitScale: 1,
        currentScale: 1,
        activePan: null,
      }};

      if (!context.viewport || !context.stage || !context.zoomLabel || !context.mermaidRoot) {{
        return;
      }}

      const svg = context.mermaidRoot.querySelector("svg");
      if (!svg) {{
        return;
      }}

      context.diagramMetrics = readDiagramMetrics(svg);
      fitDiagram(context);
      context.fitButton.addEventListener("click", () => fitDiagram(context));
      context.zoomOutButton.addEventListener("click", () => zoomBy(context, -ZOOM_STEP));
      context.zoomInButton.addEventListener("click", () => zoomBy(context, ZOOM_STEP));
      installDiagramPointerControls(context);
      window.addEventListener("resize", () => fitDiagram(context));
    }}

    function installSourceFileRefresh() {{
      let latestVersion = SOURCE_VERSION;
      const checkForChanges = async () => {{
        try {{
          const response = await fetch(`/version?ts=${{Date.now()}}`, {{ cache: "no-store" }});
          if (!response.ok) {{
            return;
          }}
          const nextVersion = (await response.text()).trim();
          if (nextVersion && nextVersion !== latestVersion) {{
            latestVersion = nextVersion;
            window.location.reload();
          }}
        }} catch (_error) {{
          // Keep the current preview if a transient poll fails.
        }}
      }};

      window.setInterval(checkForChanges, 1000);
    }}

    await mermaid.run({{
      querySelector: ".mermaid",
    }});
    for (const diagram of document.querySelectorAll(".diagram")) {{
      installDiagramControls(diagram);
    }}
    installNoteHoverTooltips(document);
    if (SOURCE_VERSION) {{
      installSourceFileRefresh();
    }}
    window.addEventListener("scroll", hideTooltip, true);
    window.addEventListener("resize", hideTooltip);
  </script>
</body>
</html>
"""


class FishyError(RuntimeError):
    """Raised when fishy cannot continue."""


class StaticPreviewSource:
    def __init__(self, mermaid_source: str, diagram_title: str):
        self._payload = PreviewPayload(
            diagrams=[MermaidDiagram(title=diagram_title, source=mermaid_source)],
            source=mermaid_source,
            source_version="",
            caption=(
                "Rendering Mermaid from stdin or a Mermaid file on a local server. "
                "Mermaid runtime loads in the browser, so the preview stays local while "
                "diagram parsing happens client-side."
            ),
        )

    def read_payload(self) -> PreviewPayload:
        return self._payload

    def read_version(self) -> str:
        return ""


class MarkdownFilePreviewSource:
    def __init__(self, path: Path):
        self.path = path

    def read_payload(self) -> PreviewPayload:
        try:
            source = self.path.read_text(encoding="utf-8")
            version = self.read_version()
        except OSError as exc:
            raise FishyError(f"failed to read Markdown source file {self.path}: {exc}") from exc

        diagrams = _extract_mermaid_blocks(source, self.path)
        return PreviewPayload(
            diagrams=diagrams,
            source=source,
            source_version=version,
            caption=(
                f"Rendering {len(diagrams)} Mermaid block"
                f"{'' if len(diagrams) == 1 else 's'} from {self.path}. "
                "This preview refreshes when the source file changes."
            ),
        )

    def read_version(self) -> str:
        try:
            stat = self.path.stat()
        except OSError:
            return "missing"
        return f"{stat.st_mtime_ns}:{stat.st_size}"


class FishyHandler(BaseHTTPRequestHandler):
    def __init__(self, *args, preview_source: StaticPreviewSource | MarkdownFilePreviewSource, title: str, **kwargs):
        self._preview_source = preview_source
        self._title = title
        super().__init__(*args, **kwargs)

    def do_GET(self) -> None:
        if self.path in {"/", "/index.html"}:
            payload = self._read_payload_or_error()
            if payload is None:
                return
            html_page = _build_html_page(self._title, payload).encode("utf-8")
            self._send_bytes(html_page, "text/html; charset=utf-8")
            return
        if self.path == "/source.mmd":
            payload = self._read_payload_or_error()
            if payload is None:
                return
            self._send_bytes(payload.source.encode("utf-8"), "text/plain; charset=utf-8")
            return
        if self.path.startswith("/version"):
            self._send_bytes(self._preview_source.read_version().encode("utf-8"), "text/plain; charset=utf-8")
            return
        if self.path == "/favicon.ico":
            self.send_response(HTTPStatus.NO_CONTENT)
            self.end_headers()
            return

        self.send_error(HTTPStatus.NOT_FOUND, "Not found")

    def log_message(self, format: str, *args) -> None:
        return

    def _read_payload_or_error(self) -> PreviewPayload | None:
        try:
            return self._preview_source.read_payload()
        except FishyError as exc:
            self.send_error(HTTPStatus.INTERNAL_SERVER_ERROR, str(exc))
            return None

    def _send_bytes(self, payload: bytes, content_type: str) -> None:
        self.send_response(HTTPStatus.OK)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)


def _parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Serve Mermaid diagrams locally from stdin, a file, or Markdown source.")
    parser.add_argument(
        "path",
        nargs="?",
        help="Mermaid file path. Omit or use '-' to read from stdin.",
    )
    parser.add_argument(
        "--source-file",
        help="Markdown source file to extract Mermaid code blocks from, with browser refresh on changes.",
    )
    parser.add_argument(
        "--host",
        default=DEFAULT_HOST,
        help=f"Address to bind (default: {DEFAULT_HOST}).",
    )
    parser.add_argument(
        "--port",
        type=int,
        default=DEFAULT_PORT,
        help="TCP port to bind (default: 0, which asks the OS for a free port).",
    )
    parser.add_argument(
        "--title",
        default=DEFAULT_TITLE,
        help=f"Page title to display (default: {DEFAULT_TITLE!r}).",
    )
    parser.add_argument(
        "--no-open",
        action="store_true",
        help="Do not open the preview in a browser automatically.",
    )
    return parser.parse_args()


def _read_mermaid_source(path_arg: str | None) -> str:
    if path_arg and path_arg != "-":
        path = Path(path_arg).expanduser()
        try:
            source = path.read_text(encoding="utf-8")
        except OSError as exc:
            raise FishyError(f"failed to read Mermaid file {path}: {exc}") from exc
    else:
        if sys.stdin.isatty():
            raise FishyError("provide Mermaid via stdin or pass a Mermaid file path")
        try:
            source = sys.stdin.read()
        except OSError as exc:
            raise FishyError(f"failed to read Mermaid from stdin: {exc}") from exc

    source = _normalize_mermaid_source(source)
    if not source.strip():
        raise FishyError("Mermaid definition is empty")
    return source


def _normalize_mermaid_source(source: str) -> str:
    trimmed = source.strip()
    if not trimmed:
        return ""

    lines = trimmed.splitlines()
    if len(lines) >= 2:
        opening = lines[0].strip()
        closing = lines[-1].strip()
        match = FENCED_BLOCK_RE.fullmatch(opening)
        if match and _is_closing_fence(closing, match.group("fence")):
            return "\n".join(lines[1:-1]).strip("\n")

    return source


def _is_closing_fence(line: str, opening_fence: str) -> bool:
    stripped = line.strip()
    fence_char = opening_fence[0]
    return (
        bool(stripped)
        and set(stripped) == {fence_char}
        and len(stripped) >= len(opening_fence)
    )


def _clean_heading_title(raw_title: str) -> str:
    return re.sub(r"[ \t]+#+[ \t]*$", "", raw_title).strip()


def _is_mermaid_info_string(info: str) -> bool:
    normalized = info.strip().lower()
    if not normalized:
        return False
    token = re.split(r"[\s,}]+", normalized.lstrip("{"), maxsplit=1)[0]
    return token.lstrip(".") == "mermaid"


def _extract_mermaid_blocks(markdown_source: str, source_path: Path) -> list[MermaidDiagram]:
    diagrams: list[MermaidDiagram] = []
    current_heading = ""
    active_fence = ""
    active_title = ""
    active_is_mermaid = False
    active_lines: list[str] = []

    for line in markdown_source.splitlines():
        if active_fence:
            if _is_closing_fence(line, active_fence):
                if active_is_mermaid:
                    diagram_source = "\n".join(active_lines).strip("\n")
                    if diagram_source.strip():
                        diagrams.append(
                            MermaidDiagram(
                                title=active_title or f"Mermaid block {len(diagrams) + 1}",
                                source=diagram_source,
                            )
                        )
                active_fence = ""
                active_title = ""
                active_is_mermaid = False
                active_lines = []
                continue

            if active_is_mermaid:
                active_lines.append(line)
            continue

        fence_match = FENCED_BLOCK_RE.fullmatch(line)
        if fence_match:
            active_fence = fence_match.group("fence")
            active_title = current_heading
            active_is_mermaid = _is_mermaid_info_string(fence_match.group("info"))
            active_lines = []
            continue

        heading_match = ATX_HEADING_RE.fullmatch(line)
        if heading_match:
            heading_title = _clean_heading_title(heading_match.group("title"))
            if heading_title:
                current_heading = heading_title

    if not diagrams:
        raise FishyError(f"no Mermaid code blocks found in {source_path}")

    return diagrams


def _render_diagram_sections(diagrams: list[MermaidDiagram]) -> str:
    sections = []
    for index, diagram in enumerate(diagrams, start=1):
        sections.append(
            DIAGRAM_SECTION_TEMPLATE.format(
                index=index,
                title=html.escape(diagram.title),
                diagram=html.escape(diagram.source),
            )
        )
    return "\n".join(sections)


def _build_html_page(title: str, payload: PreviewPayload) -> str:
    return PAGE_TEMPLATE.format(
        title=html.escape(title),
        caption=html.escape(payload.caption),
        diagrams=_render_diagram_sections(payload.diagrams),
        source_version=html.escape(payload.source_version, quote=True),
        mermaid_url=html.escape(MERMAID_MODULE_URL, quote=True),
    )


def _display_host(bound_host: str, requested_host: str) -> str:
    if requested_host in {"0.0.0.0", "::", ""}:
        return "127.0.0.1"
    return bound_host


def main() -> int:
    args = _parse_args()
    if args.port < 0 or args.port > 65535:
        print("fishy: --port must be between 0 and 65535", file=sys.stderr)
        return 1
    if args.source_file and args.path:
        print("fishy: pass either --source-file or a Mermaid path/stdin, not both", file=sys.stderr)
        return 1

    try:
        if args.source_file:
            preview_source = MarkdownFilePreviewSource(Path(args.source_file).expanduser())
        else:
            preview_source = StaticPreviewSource(_read_mermaid_source(args.path), args.title)
        preview_source.read_payload()
    except FishyError as exc:
        print(f"fishy: {exc}", file=sys.stderr)
        return 1

    handler = partial(
        FishyHandler,
        preview_source=preview_source,
        title=args.title,
    )

    try:
        with ThreadingHTTPServer((args.host, args.port), handler) as server:
            bound_host, bound_port = server.server_address[:2]
            url = f"http://{_display_host(bound_host, args.host)}:{bound_port}"
            print(f"fishy serving Mermaid preview at {url}", flush=True)
            if not args.no_open:
                webbrowser.open(url)
            try:
                server.serve_forever()
            except KeyboardInterrupt:
                print("\nfishy stopped", flush=True)
    except OSError as exc:
        print(f"fishy: failed to start server: {exc}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
