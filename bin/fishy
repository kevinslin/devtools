      background:
        radial-gradient(circle at top left, rgba(48, 170, 196, 0.22), transparent 28rem),
        linear-gradient(180deg, #eefaff 0%, var(--bg) 48%, #fcfeff 100%);
    }}

    main {{
      width: 100%;
      min-height: 100vh;
