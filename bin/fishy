    a {{
      color: var(--accent);
      text-decoration: none;
    }}

    a:hover {{
      text-decoration: underline;
    }}
  </style>
</head>
<body>
  <main>
    <section class="panel hero">
      <p class="eyebrow">fishy</p>
      <h1>{title}</h1>
      <p class="caption">Rendering Mermaid from stdin on a local server. Mermaid runtime loads in the browser, so the preview stays local while diagram parsing happens client-side.</p>
      <p class="caption"><a href="/source.mmd">download source</a></p>
    </section>
    <section class="panel diagram">
      <div class="diagram-toolbar">
        <div class="diagram-toolbar-group">
          <span>View</span>
          <strong class="diagram-zoom-label" id="diagram-zoom-label">100%</strong>
        </div>
        <div class="diagram-toolbar-group">
          <button type="button" id="diagram-fit-button">Fit width</button>
          <button type="button" id="diagram-zoom-out-button">-</button>
          <button type="button" id="diagram-zoom-in-button">+</button>
        </div>
      </div>
      <div class="diagram-viewport" id="diagram-viewport">
        <div class="diagram-stage-wrap">
          <div class="diagram-stage" id="diagram-stage">
            <pre class="mermaid" id="diagram-mermaid">{diagram}</pre>
          </div>
        </div>
      </div>
    </section>
    <details class="panel">
      <summary>Source</summary>
      <pre class="source">{diagram}</pre>
    </details>
  </main>
  <div class="note-hover-tooltip" id="note-hover-tooltip" hidden></div>
  <script type="module">
    import mermaid from "{mermaid_url}";

    mermaid.initialize({{
      startOnLoad: false,
      sequence: {{
        useMaxWidth: false,
      }},
      flowchart: {{
        useMaxWidth: false,
      }},
      securityLevel: "strict",
      theme: "neutral",
    }});

    const tooltip = document.getElementById("note-hover-tooltip");
    const viewport = document.getElementById("diagram-viewport");
    const stage = document.getElementById("diagram-stage");
    const zoomLabel = document.getElementById("diagram-zoom-label");
    const fitButton = document.getElementById("diagram-fit-button");
    const zoomOutButton = document.getElementById("diagram-zoom-out-button");
    const zoomInButton = document.getElementById("diagram-zoom-in-button");
    const mermaidRoot = document.getElementById("diagram-mermaid");
    const ZOOM_STEP = 0.15;
    const DOUBLE_CLICK_ZOOM = 1.5;
    const MIN_SCALE = 0.05;
    const MAX_SCALE = 3;
    let diagramMetrics = null;
    let fitScale = 1;
    let currentScale = 1;
    let activePan = null;

    function getNoteLabel(noteTextNode) {{
      const tspans = Array.from(noteTextNode.querySelectorAll("tspan"))
        .map((node) => (node.textContent || "").trim())
        .filter(Boolean);
      if (tspans.length > 0) {{
        return tspans.join(" ");
      }}
      return (noteTextNode.textContent || "").trim();
    }}

    function positionTooltip(anchorRect) {{
      if (tooltip.hidden) {{
        return;
      }}

      const margin = 12;
      const tooltipRect = tooltip.getBoundingClientRect();
      let left = anchorRect.left + (anchorRect.width / 2) - (tooltipRect.width / 2);
      left = Math.max(margin, Math.min(left, window.innerWidth - tooltipRect.width - margin));

      let top = anchorRect.top - tooltipRect.height - margin;
      if (top < margin) {{
        top = Math.min(anchorRect.bottom + margin, window.innerHeight - tooltipRect.height - margin);
      }}

      tooltip.style.left = `${{left}}px`;
      tooltip.style.top = `${{Math.max(margin, top)}}px`;
    }}

    function showTooltip(label, anchorRect) {{
      tooltip.textContent = label;
      tooltip.hidden = false;
      tooltip.dataset.visible = "true";
      positionTooltip(anchorRect);
    }}

    function hideTooltip() {{
      tooltip.hidden = true;
      delete tooltip.dataset.visible;
    }}

    function attachNoteHover(textNode) {{
      const label = getNoteLabel(textNode);
      if (!label) {{
        return;
      }}

      const group = textNode.closest("g");
      if (group && !group.querySelector("title")) {{
        const title = document.createElementNS("http://www.w3.org/2000/svg", "title");
        title.textContent = label;
        group.prepend(title);
      }}

      const hoverTargets = [textNode];
      const noteBox = group ? group.querySelector("rect.note") : null;
      if (noteBox) {{
        hoverTargets.push(noteBox);
      }}

      for (const target of hoverTargets) {{
        target.style.cursor = "help";
        target.addEventListener("mouseenter", () => showTooltip(label, target.getBoundingClientRect()));
        target.addEventListener("mousemove", () => showTooltip(label, target.getBoundingClientRect()));
        target.addEventListener("mouseleave", hideTooltip);
      }}
    }}

    function installNoteHoverTooltips() {{
      for (const textNode of document.querySelectorAll("svg .noteText")) {{
        attachNoteHover(textNode);
      }}
    }}

    function setZoomLabel(scale) {{
      zoomLabel.textContent = `${{Math.round(scale * 100)}}%`;
    }}

    function readDiagramMetrics(svg) {{
      const viewBox = svg.viewBox?.baseVal;
      if (viewBox && viewBox.width > 0 && viewBox.height > 0) {{
        return {{
          width: viewBox.width,
          height: viewBox.height,
        }};
      }}

      const bbox = svg.getBBox();
      return {{
        width: Math.max(1, bbox.width),
        height: Math.max(1, bbox.height),
      }};
    }}

    function clampScale(scale) {{
      return Math.max(MIN_SCALE, Math.min(scale, MAX_SCALE));
    }}

    function getViewportPadding() {{
      const style = window.getComputedStyle(viewport);
      return {{
        x: (Number.parseFloat(style.paddingLeft) || 0) + (Number.parseFloat(style.paddingRight) || 0),
        y: (Number.parseFloat(style.paddingTop) || 0) + (Number.parseFloat(style.paddingBottom) || 0),
      }};
    }}

    function applyScale(scale) {{
      const svg = mermaidRoot.querySelector("svg");
      if (!svg || !diagramMetrics) {{
        return;
      }}

      currentScale = clampScale(scale);
      svg.style.width = `${{diagramMetrics.width * currentScale}}px`;
      svg.style.height = `${{diagramMetrics.height * currentScale}}px`;
      svg.style.maxWidth = "none";
      svg.style.transform = "none";
      stage.style.width = `${{diagramMetrics.width * currentScale}}px`;
      stage.style.height = `${{diagramMetrics.height * currentScale}}px`;
      stage.dataset.scale = currentScale.toFixed(4);
      setZoomLabel(currentScale);
    }}

    function fitDiagram() {{
      if (!diagramMetrics) {{
        return;
      }}

      const padding = getViewportPadding();
      const availableWidth = Math.max(1, viewport.clientWidth - padding.x);
      fitScale = clampScale(availableWidth / diagramMetrics.width);
      applyScale(fitScale);
      viewport.scrollTop = 0;
      viewport.scrollLeft = 0;
    }}

    function getViewportCenterPoint() {{
      const rect = viewport.getBoundingClientRect();
      return {{
        x: rect.left + (rect.width / 2),
        y: rect.top + (rect.height / 2),
      }};
    }}

    function zoomAt(scale, clientX, clientY) {{
      const svg = mermaidRoot.querySelector("svg");
      if (!svg || !diagramMetrics) {{
        return;
      }}

      const nextScale = clampScale(scale);
      if (Math.abs(nextScale - currentScale) < 0.0001) {{
        return;
      }}

      const beforeRect = stage.getBoundingClientRect();
      const focusX = (clientX - beforeRect.left) / currentScale;
      const focusY = (clientY - beforeRect.top) / currentScale;
      applyScale(nextScale);
      const afterRect = stage.getBoundingClientRect();
      viewport.scrollLeft += (afterRect.left + (focusX * currentScale)) - clientX;
      viewport.scrollTop += (afterRect.top + (focusY * currentScale)) - clientY;
    }}

    function zoomBy(delta) {{
      const point = getViewportCenterPoint();
      zoomAt(currentScale + delta, point.x, point.y);
    }}

    function endPan(event) {{
      if (!activePan || activePan.pointerId !== event.pointerId) {{
        return;
      }}

      if (viewport.hasPointerCapture(event.pointerId)) {{
        viewport.releasePointerCapture(event.pointerId);
      }}
      activePan = null;
      viewport.classList.remove("is-panning");
    }}

    function installDiagramPointerControls() {{
      viewport.addEventListener("pointerdown", (event) => {{
        if (event.button !== 0) {{
          return;
        }}

        activePan = {{
          pointerId: event.pointerId,
          startX: event.clientX,
          startY: event.clientY,
          scrollLeft: viewport.scrollLeft,
          scrollTop: viewport.scrollTop,
        }};
        viewport.classList.add("is-panning");
        viewport.setPointerCapture(event.pointerId);
      }});

      viewport.addEventListener("pointermove", (event) => {{
        if (!activePan || activePan.pointerId !== event.pointerId) {{
          return;
        }}

        viewport.scrollLeft = activePan.scrollLeft - (event.clientX - activePan.startX);
        viewport.scrollTop = activePan.scrollTop - (event.clientY - activePan.startY);
        hideTooltip();
        event.preventDefault();
      }});

      viewport.addEventListener("pointerup", endPan);
      viewport.addEventListener("pointercancel", endPan);
      viewport.addEventListener("lostpointercapture", endPan);
      viewport.addEventListener("dblclick", (event) => {{
        event.preventDefault();
        const nextScale = (event.altKey || event.shiftKey)
          ? currentScale / DOUBLE_CLICK_ZOOM
          : currentScale * DOUBLE_CLICK_ZOOM;
        zoomAt(nextScale, event.clientX, event.clientY);
      }});
    }}

    await mermaid.run({{
      querySelector: ".mermaid",
    }});
    const svg = mermaidRoot.querySelector("svg");
    if (svg) {{
      diagramMetrics = readDiagramMetrics(svg);
      fitDiagram();
      fitButton.addEventListener("click", fitDiagram);
      zoomOutButton.addEventListener("click", () => zoomBy(-ZOOM_STEP));
      zoomInButton.addEventListener("click", () => zoomBy(ZOOM_STEP));
      installDiagramPointerControls();
      window.addEventListener("resize", fitDiagram);
    }}
    installNoteHoverTooltips();
    window.addEventListener("scroll", hideTooltip, true);
    window.addEventListener("resize", hideTooltip);
  </script>
</body>
</html>
"""


class FishyError(RuntimeError):
    """Raised when fishy cannot continue."""


class FishyHandler(BaseHTTPRequestHandler):
    def __init__(self, *args, html_page: bytes, mermaid_source: bytes, **kwargs):
        self._html_page = html_page
        self._mermaid_source = mermaid_source
        super().__init__(*args, **kwargs)

    def do_GET(self) -> None:
        if self.path in {"/", "/index.html"}:
            self._send_bytes(self._html_page, "text/html; charset=utf-8")
            return
        if self.path == "/source.mmd":
            self._send_bytes(self._mermaid_source, "text/plain; charset=utf-8")
            return
        if self.path == "/favicon.ico":
            self.send_response(HTTPStatus.NO_CONTENT)
            self.end_headers()
            return

        self.send_error(HTTPStatus.NOT_FOUND, "Not found")

    def log_message(self, format: str, *args) -> None:
        return

    def _send_bytes(self, payload: bytes, content_type: str) -> None:
        self.send_response(HTTPStatus.OK)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)


def _parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Serve a Mermaid diagram locally from stdin or a file.")
    parser.add_argument(
        "path",
        nargs="?",
        help="Mermaid file path. Omit or use '-' to read from stdin.",
    )
    parser.add_argument(
        "--host",
        default=DEFAULT_HOST,
        help=f"Address to bind (default: {DEFAULT_HOST}).",
    )
    parser.add_argument(
        "--port",
        type=int,
        default=DEFAULT_PORT,
        help="TCP port to bind (default: 0, which asks the OS for a free port).",
    )
    parser.add_argument(
        "--title",
        default=DEFAULT_TITLE,
        help=f"Page title to display (default: {DEFAULT_TITLE!r}).",
    )
    parser.add_argument(
        "--no-open",
        action="store_true",
        help="Do not open the preview in a browser automatically.",
    )
    return parser.parse_args()


def _read_mermaid_source(path_arg: str | None) -> str:
    if path_arg and path_arg != "-":
        path = Path(path_arg).expanduser()
        try:
            source = path.read_text(encoding="utf-8")
        except OSError as exc:
            raise FishyError(f"failed to read Mermaid file {path}: {exc}") from exc
    else:
        if sys.stdin.isatty():
            raise FishyError("provide Mermaid via stdin or pass a Mermaid file path")
        try:
            source = sys.stdin.read()
        except OSError as exc:
            raise FishyError(f"failed to read Mermaid from stdin: {exc}") from exc

    source = _normalize_mermaid_source(source)
    if not source.strip():
        raise FishyError("Mermaid definition is empty")
    return source


def _normalize_mermaid_source(source: str) -> str:
    trimmed = source.strip()
    if not trimmed:
        return ""

    lines = trimmed.splitlines()
    if len(lines) >= 2:
        opening = lines[0].strip()
        closing = lines[-1].strip()
        match = FENCED_BLOCK_RE.fullmatch(opening)
        if match and closing == match.group("fence"):
            return "\n".join(lines[1:-1]).strip("\n")

    return source


def _build_html_page(title: str, mermaid_source: str) -> str:
    return PAGE_TEMPLATE.format(
        title=html.escape(title),
        diagram=html.escape(mermaid_source),
        mermaid_url=html.escape(MERMAID_MODULE_URL, quote=True),
    )


def _display_host(bound_host: str, requested_host: str) -> str:
    if requested_host in {"0.0.0.0", "::", ""}:
        return "127.0.0.1"
    return bound_host


def main() -> int:
    args = _parse_args()
    if args.port < 0 or args.port > 65535:
        print("fishy: --port must be between 0 and 65535", file=sys.stderr)
        return 1

    try:
        mermaid_source = _read_mermaid_source(args.path)
    except FishyError as exc:
        print(f"fishy: {exc}", file=sys.stderr)
        return 1

    html_page = _build_html_page(args.title, mermaid_source).encode("utf-8")
    handler = partial(
        FishyHandler,
        html_page=html_page,
        mermaid_source=mermaid_source.encode("utf-8"),
    )

    try:
        with ThreadingHTTPServer((args.host, args.port), handler) as server:
            bound_host, bound_port = server.server_address[:2]
            url = f"http://{_display_host(bound_host, args.host)}:{bound_port}"
            print(f"fishy serving Mermaid preview at {url}", flush=True)
            if not args.no_open:
                webbrowser.open(url)
            try:
                server.serve_forever()
            except KeyboardInterrupt:
                print("\nfishy stopped", flush=True)
    except OSError as exc:
        print(f"fishy: failed to start server: {exc}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
