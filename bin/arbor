#!/usr/bin/env python3
"""Manage git branches and worktrees.

Usage:
  arbor clean [--base BRANCH] [--dry-run] [--force]
  arbor delete <target> [--force]
  arbor checkout [worktree]
  arbor convert-to-worktree [worktree] [--base BRANCH]
  arbor push-force
"""

from __future__ import annotations

import argparse
import os
import re
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path


class ArborError(RuntimeError):
    """Raised when arbor cannot continue due to an invalid git state."""


@dataclass
class WorktreeEntry:
    path: Path
    branch: str | None


@dataclass
class WorktreeMatch:
    entry: WorktreeEntry
    matched_by_path: bool


def _run_git(repo: Path, args: list[str], *, check: bool = True) -> subprocess.CompletedProcess[str]:
    result = subprocess.run(
        ["git", *args],
        cwd=repo,
        capture_output=True,
        text=True,
        check=False,
    )
    if check and result.returncode != 0:
        stderr = result.stderr.strip() or result.stdout.strip() or "git command failed"
        raise ArborError(f"git {' '.join(args)}: {stderr}")
    return result


def _repo_root(cwd: Path | None = None) -> Path:
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        cwd=cwd,
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        stderr = result.stderr.strip() or "not inside a git repository"
        raise ArborError(stderr)
    return Path(result.stdout.strip()).resolve()


def _current_branch(repo: Path) -> str | None:
    result = _run_git(repo, ["symbolic-ref", "--quiet", "--short", "HEAD"], check=False)
    branch = result.stdout.strip()
    return branch if result.returncode == 0 and branch else None


def _detect_base_ref(repo: Path) -> str:
    remote_head = _run_git(
        repo,
        ["symbolic-ref", "--quiet", "--short", "refs/remotes/origin/HEAD"],
        check=False,
    )
    remote_name = remote_head.stdout.strip()
    if remote_head.returncode == 0 and remote_name:
        return remote_name

    current = _current_branch(repo)
    if current:
        return current

    raise ArborError("cannot infer a base branch; use --base <branch>")


def _normalize_branch_name(ref: str) -> str:
    if ref.startswith("refs/heads/"):
        return ref.removeprefix("refs/heads/")
    if ref.startswith("refs/remotes/origin/"):
        return ref.removeprefix("refs/remotes/origin/")
    if ref.startswith("origin/"):
        return ref.removeprefix("origin/")
    return ref


def _merged_local_branches(repo: Path, base_ref: str) -> set[str]:
    result = _run_git(
        repo,
        ["for-each-ref", "--format=%(refname:short)", "--merged", base_ref, "refs/heads"],
    )
    return {line.strip() for line in result.stdout.splitlines() if line.strip()}


def _parse_worktrees(raw: str) -> list[WorktreeEntry]:
    entries: list[WorktreeEntry] = []
    current: dict[str, str] = {}
    for line in raw.splitlines():
        if not line.strip():
            if current:
                path = current.get("worktree")
                if path:
                    branch_ref = current.get("branch")
                    branch = _normalize_branch_name(branch_ref) if branch_ref else None
                    entries.append(WorktreeEntry(path=Path(path), branch=branch))
            current = {}
            continue
        key, _, value = line.partition(" ")
        current[key] = value

    if current:
        path = current.get("worktree")
        if path:
            branch_ref = current.get("branch")
            branch = _normalize_branch_name(branch_ref) if branch_ref else None
            entries.append(WorktreeEntry(path=Path(path), branch=branch))

    return entries


def _list_worktrees(repo: Path) -> list[WorktreeEntry]:
    result = _run_git(repo, ["worktree", "list", "--porcelain"])
    return _parse_worktrees(result.stdout)


def _common_git_dir(repo: Path) -> Path:
    result = _run_git(repo, ["rev-parse", "--git-common-dir"])
    common_dir = Path(result.stdout.strip())
    if common_dir.is_absolute():
        return common_dir.resolve()
    return (repo / common_dir).resolve()


def _shared_repo_root(repo: Path) -> Path:
    return _common_git_dir(repo).parent.resolve()


def _local_branch_exists(repo: Path, branch: str) -> bool:
    result = _run_git(repo, ["show-ref", "--verify", "--quiet", f"refs/heads/{branch}"], check=False)
    return result.returncode == 0


def _match_worktree_target(repo: Path, target: str, worktrees: list[WorktreeEntry]) -> WorktreeMatch | None:
    cwd = Path.cwd()
    non_primary = [entry for entry in worktrees if entry.path.resolve() != repo.resolve()]
    normalized_target_path = Path(target).expanduser().resolve(strict=False) if Path(target).is_absolute() else None

    path_matches: list[WorktreeEntry] = []
    for entry in non_primary:
        tokens = {str(entry.path), str(entry.path.resolve())}
        try:
            tokens.add(os.path.relpath(entry.path, cwd))
        except ValueError:
            pass
        if target in tokens or (normalized_target_path and entry.path.resolve() == normalized_target_path):
            path_matches.append(entry)

    if len(path_matches) == 1:
        return WorktreeMatch(entry=path_matches[0], matched_by_path=True)
    if len(path_matches) > 1:
        raise ArborError(f"multiple worktrees match path {target}; use a more specific path")

    name_matches = [entry for entry in non_primary if entry.path.name == target]
    if len(name_matches) == 1:
        return WorktreeMatch(entry=name_matches[0], matched_by_path=False)
    if len(name_matches) > 1:
        raise ArborError(f"multiple worktrees match name {target}; use a path instead")
    return None


def _remove_worktree(repo: Path, path: Path, *, force: bool) -> None:
    remove_args = ["worktree", "remove"]
    if force:
        remove_args.append("--force")
    remove_args.append(str(path))
    result = _run_git(repo, remove_args, check=False)
    if result.returncode == 0:
        return

    err = result.stderr.strip() or result.stdout.strip() or f"failed to remove worktree {path}"
    raise ArborError(f"worktree {path}: {err}")


def _delete_branch(repo: Path, branch: str) -> None:
    result = _run_git(repo, ["branch", "-D", branch], check=False)
    if result.returncode == 0:
        return

    err = result.stderr.strip() or result.stdout.strip() or f"failed to delete branch {branch}"
    raise ArborError(f"branch {branch}: {err}")


def _checkout_is_dirty(repo: Path) -> bool:
    result = _run_git(repo, ["status", "--short"])
    return bool(result.stdout.strip())


def _list_remotes(repo: Path) -> list[str]:
    result = _run_git(repo, ["remote"])
    return [line.strip() for line in result.stdout.splitlines() if line.strip()]


def _resolve_local_base_branch(repo: Path, current_branch: str, base_arg: str | None) -> str:
    candidates: list[str] = []
    if base_arg:
        candidates.append(_normalize_branch_name(base_arg))
    else:
        remote_head = _run_git(
            repo,
            ["symbolic-ref", "--quiet", "--short", "refs/remotes/origin/HEAD"],
            check=False,
        )
        remote_name = remote_head.stdout.strip()
        if remote_head.returncode == 0 and remote_name:
            candidates.append(_normalize_branch_name(remote_name))
        candidates.extend(["main", "master"])

    for candidate in candidates:
        if candidate == current_branch:
            continue
        if _local_branch_exists(repo, candidate):
            return candidate

    raise ArborError(
        "cannot infer a local base branch for convert-to-worktree; use --base <branch>"
    )


def _default_worktree_path(repo: Path, branch: str) -> Path:
    slug = re.sub(r"[^A-Za-z0-9._-]+", "-", branch).strip("-") or "branch"
    return (repo.parent / f"wt-{slug}").resolve()


def _resolve_convert_worktree_path(repo: Path, target: str | None, branch: str) -> Path:
    worktree_path = (
        Path(target).expanduser().resolve(strict=False)
        if target
        else _default_worktree_path(repo, branch)
    )
    if worktree_path == repo.resolve():
        raise ArborError("convert-to-worktree target cannot be the main repo checkout path")

    worktrees = _list_worktrees(repo)
    if any(entry.path.resolve() == worktree_path for entry in worktrees):
        raise ArborError(f"worktree path is already linked: {worktree_path}")
    if worktree_path.exists():
        raise ArborError(f"worktree path already exists: {worktree_path}")
    return worktree_path


def _resolve_push_target(repo: Path) -> tuple[str, str]:
    branch = _current_branch(repo)
    if not branch:
        raise ArborError("push-force requires a named branch; current HEAD is detached")

    remote_result = _run_git(repo, ["config", "--get", f"branch.{branch}.remote"], check=False)
    merge_result = _run_git(repo, ["config", "--get", f"branch.{branch}.merge"], check=False)
    remote = remote_result.stdout.strip()
    merge_ref = merge_result.stdout.strip()
    if remote and merge_ref:
        return remote, _normalize_branch_name(merge_ref)

    remotes = _list_remotes(repo)
    if "origin" in remotes:
        return "origin", branch
    if len(remotes) == 1:
        return remotes[0], branch

    raise ArborError(
        f"cannot infer a push remote for branch {branch}; configure an upstream or add an origin remote"
    )


def _remove_stale_worktree(repo: Path, worktree_path: Path) -> None:
    remove_result = _run_git(repo, ["worktree", "remove", "--force", str(worktree_path)], check=False)
    remove_error = remove_result.stderr.strip() or remove_result.stdout.strip()
    worktree_exists = worktree_path.exists()
    still_registered = any(entry.path.resolve() == worktree_path.resolve() for entry in _list_worktrees(repo))

    if worktree_exists or still_registered:
        if worktree_exists:
            try:
                shutil.rmtree(worktree_path)
            except OSError as exc:
                raise ArborError(f"worktree {worktree_path}: failed to remove directory: {exc}") from exc
        _run_git(repo, ["worktree", "prune"])

    worktree_exists = worktree_path.exists()
    still_registered = any(entry.path.resolve() == worktree_path.resolve() for entry in _list_worktrees(repo))
    if worktree_exists or still_registered:
        err = remove_error or f"failed to remove worktree {worktree_path}"
        raise ArborError(f"worktree {worktree_path}: {err}")


def _resolve_checkout_worktree(target: str | None) -> tuple[Path, Path]:
    current_checkout = _repo_root()
    repo_root = _shared_repo_root(current_checkout)
    if target is None:
        if current_checkout.resolve() == repo_root.resolve():
            raise ArborError("checkout requires a worktree path when run from the main repo checkout")
        return current_checkout.resolve(), repo_root

    worktree_match = _match_worktree_target(repo_root, target, _list_worktrees(repo_root))
    if not worktree_match:
        raise ArborError(f"no linked worktree matches {target}")
    return worktree_match.entry.path.resolve(), repo_root


def _cmd_clean(base_arg: str | None, dry_run: bool, force: bool) -> int:
    repo = _repo_root()
    base_ref = base_arg or _detect_base_ref(repo)
    merged = _merged_local_branches(repo, base_ref)

    if not merged:
        print(f"Base reference: {base_ref}")
        print("No merged local branches found.")
        return 0

    base_branch = _normalize_branch_name(base_ref)
    current = _current_branch(repo)
    protected = {base_branch}
    if current:
        protected.add(current)

    removed_worktrees: list[Path] = []
    planned_worktree_removals: list[WorktreeEntry] = []
    deleted_branches: list[str] = []
    skipped_branches: list[str] = []
    failures: list[str] = []

    worktrees = _list_worktrees(repo)
    for entry in worktrees:
        if entry.path.resolve() == repo.resolve():
            continue
        if not entry.branch or entry.branch not in merged:
            continue
        if entry.branch in protected:
            skipped_branches.append(entry.branch)
            continue

        if dry_run:
            planned_worktree_removals.append(entry)
            removed_worktrees.append(entry.path)
            continue

        remove_args = ["worktree", "remove"]
        if force:
            remove_args.append("--force")
        remove_args.append(str(entry.path))
        result = _run_git(repo, remove_args, check=False)
        if result.returncode == 0:
            removed_worktrees.append(entry.path)
            continue

        err = result.stderr.strip() or result.stdout.strip() or f"failed to remove worktree {entry.path}"
        failures.append(f"worktree {entry.path}: {err}")

    if dry_run:
        active_branches = {entry.branch for entry in worktrees if entry.branch}
        for entry in planned_worktree_removals:
            if entry.branch:
                active_branches.discard(entry.branch)
    else:
        active_branches = {entry.branch for entry in _list_worktrees(repo) if entry.branch}

    for branch in sorted(merged):
        if branch in protected:
            skipped_branches.append(branch)
            continue
        if branch in active_branches:
            skipped_branches.append(branch)
            continue

        if dry_run:
            deleted_branches.append(branch)
            continue

        result = _run_git(repo, ["branch", "-d", branch], check=False)
        if result.returncode == 0:
            deleted_branches.append(branch)
            continue

        err = result.stderr.strip() or result.stdout.strip() or f"failed to delete branch {branch}"
        failures.append(f"branch {branch}: {err}")

    print(f"Base reference: {base_ref}")
    if dry_run and force:
        worktree_action = "would force remove worktree"
    elif dry_run:
        worktree_action = "would remove worktree"
    elif force:
        worktree_action = "force removed worktree"
    else:
        worktree_action = "removed worktree"
    branch_action = "would delete branch" if dry_run else "deleted branch"
    for path in removed_worktrees:
        print(f"{worktree_action}: {path}")
    for branch in deleted_branches:
        print(f"{branch_action}: {branch}")
    for branch in sorted(set(skipped_branches)):
        print(f"skipped branch: {branch}")

    print(
        "clean complete: "
        f"{len(removed_worktrees)} worktrees removed, "
        f"{len(deleted_branches)} branches deleted, "
        f"{len(set(skipped_branches))} branches skipped"
    )
    if dry_run:
        print("dry-run mode: no changes made")

    if failures:
        for error in failures:
            print(f"error: {error}", file=sys.stderr)
        return 1
    return 0


def _cmd_delete(target: str, force: bool) -> int:
    repo = _repo_root()
    worktrees = _list_worktrees(repo)
    worktree_match = _match_worktree_target(repo, target, worktrees)
    branch_exists = _local_branch_exists(repo, target)

    if worktree_match and (worktree_match.matched_by_path or not branch_exists):
        _remove_worktree(repo, worktree_match.entry.path, force=force)
        action = "force removed worktree" if force else "removed worktree"
        print(f"{action}: {worktree_match.entry.path}")
        return 0

    if not branch_exists:
        raise ArborError(f"no local branch or linked worktree matches {target}")

    current = _current_branch(repo)
    if current == target:
        raise ArborError(f"cannot delete the current branch: {target}")

    linked_worktrees = [
        entry
        for entry in worktrees
        if entry.branch == target and entry.path.resolve() != repo.resolve()
    ]
    for entry in linked_worktrees:
        _remove_worktree(repo, entry.path, force=force)
        action = "force removed worktree" if force else "removed worktree"
        print(f"{action}: {entry.path}")

    _delete_branch(repo, target)
    print(f"deleted branch: {target}")
    return 0


def _cmd_checkout(target: str | None) -> int:
    worktree_path, repo_root = _resolve_checkout_worktree(target)
    if worktree_path.resolve() == repo_root.resolve():
        raise ArborError(f"{worktree_path} is already the main repo checkout")

    branch_name = _current_branch(worktree_path)
    if not branch_name:
        raise ArborError(f"worktree is detached and cannot be converted automatically: {worktree_path}")

    dirty_locations: list[str] = []
    if _checkout_is_dirty(worktree_path):
        dirty_locations.append(f"worktree checkout has uncommitted changes: {worktree_path}")
    if _checkout_is_dirty(repo_root):
        dirty_locations.append(f"main repo checkout has uncommitted changes: {repo_root}")
    if dirty_locations:
        raise ArborError("; ".join(dirty_locations))

    _run_git(worktree_path, ["switch", "--detach"])
    _run_git(repo_root, ["switch", "--ignore-other-worktrees", branch_name])
    _remove_stale_worktree(repo_root, worktree_path)

    main_status = _run_git(repo_root, ["status", "--short", "--branch"])
    removed = not worktree_path.exists() and not any(
        entry.path.resolve() == worktree_path.resolve() for entry in _list_worktrees(repo_root)
    )
    print(f"main checkout: {repo_root}")
    print(f"branch: {branch_name}")
    print(f"worktree removed: {'yes' if removed else 'no'}")
    print(main_status.stdout.strip())
    return 0


def _cmd_convert_to_worktree(target: str | None, base_arg: str | None) -> int:
    repo = _repo_root()
    shared_repo = _shared_repo_root(repo)
    if repo.resolve() != shared_repo.resolve():
        raise ArborError("convert-to-worktree must be run from the main repo checkout")
    if _checkout_is_dirty(repo):
        raise ArborError(f"main repo checkout has uncommitted changes: {repo}")

    branch = _current_branch(repo)
    if not branch:
        raise ArborError("convert-to-worktree requires a named branch; current HEAD is detached")

    base_branch = _resolve_local_base_branch(repo, branch, base_arg)
    worktree_path = _resolve_convert_worktree_path(repo, target, branch)

    worktree_created = False
    switched_main = False
    try:
        _run_git(repo, ["worktree", "add", "--detach", str(worktree_path), base_branch])
        worktree_created = True
        _run_git(repo, ["switch", base_branch])
        switched_main = True
        _run_git(worktree_path, ["switch", branch])
    except ArborError as exc:
        rollback_failures: list[str] = []
        if switched_main:
            rollback = _run_git(repo, ["switch", branch], check=False)
            if rollback.returncode != 0:
                rollback_err = rollback.stderr.strip() or rollback.stdout.strip() or "rollback failed"
                rollback_failures.append(f"failed to switch main checkout back to {branch}: {rollback_err}")
        if worktree_created:
            try:
                _remove_stale_worktree(repo, worktree_path)
            except ArborError as cleanup_exc:
                rollback_failures.append(str(cleanup_exc))
        if rollback_failures:
            raise ArborError(f"{exc}; rollback issues: {'; '.join(rollback_failures)}") from exc
        raise

    print(f"main checkout: {repo}")
    print(f"base branch: {base_branch}")
    print(f"branch moved to worktree: {branch}")
    print(f"worktree: {worktree_path}")
    print(_run_git(repo, ["status", "--short", "--branch"]).stdout.strip())
    return 0


def _cmd_push_force() -> int:
    repo = _repo_root()
    branch = _current_branch(repo)
    if not branch:
        raise ArborError("push-force requires a named branch; current HEAD is detached")

    remote, remote_branch = _resolve_push_target(repo)
    result = subprocess.run(
        ["git", "push", "--force-with-lease", remote, f"HEAD:{remote_branch}"],
        cwd=repo,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        raise ArborError(
            f"git push --force-with-lease {remote} HEAD:{remote_branch} failed with exit code {result.returncode}"
        )
    print(f"force pushed branch: {branch} -> {remote}/{remote_branch}")
    return 0


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Manage git branches and worktrees.")
    subparsers = parser.add_subparsers(dest="command")

    clean_parser = subparsers.add_parser(
        "clean",
        help="Remove fully merged local branches and their linked worktrees.",
    )
    clean_parser.add_argument(
        "--base",
        help="Base branch/reference for merge checks (default: origin HEAD or current branch).",
    )
    clean_parser.add_argument(
        "-n",
        "--dry-run",
        action="store_true",
        help="Preview removals without modifying branches or worktrees.",
    )
    clean_parser.add_argument(
        "-f",
        "--force",
        action="store_true",
        help="Force worktree removal, including worktrees with modified files.",
    )

    delete_parser = subparsers.add_parser(
        "delete",
        help="Delete a local branch or remove a linked worktree target.",
    )
    delete_parser.add_argument(
        "target",
        help="Branch name, linked worktree path, or unique linked worktree directory name.",
    )
    delete_parser.add_argument(
        "-f",
        "--force",
        action="store_true",
        help="Force worktree removal when the target worktree contains modified files.",
    )

    checkout_parser = subparsers.add_parser(
        "checkout",
        help="Convert a linked worktree checkout back into the main repo checkout.",
    )
    checkout_parser.add_argument(
        "worktree",
        nargs="?",
        help="Linked worktree path or unique directory name. Defaults to the current worktree when run inside one.",
    )

    convert_parser = subparsers.add_parser(
        "convert-to-worktree",
        help="Move the current branch from the main repo checkout into a linked worktree.",
    )
    convert_parser.add_argument(
        "worktree",
        nargs="?",
        help="Linked worktree path to create. Defaults to a sibling `wt-<branch>` directory.",
    )
    convert_parser.add_argument(
        "--base",
        help="Local branch to leave checked out in the main repo (default: origin/HEAD, main, or master).",
    )

    subparsers.add_parser(
        "push-force",
        help="Force-push the current branch with lease to its upstream or inferred remote branch.",
    )

    args = parser.parse_args(argv)
    if args.command == "clean":
        return _cmd_clean(args.base, args.dry_run, args.force)
    if args.command == "delete":
        return _cmd_delete(args.target, args.force)
    if args.command == "checkout":
        return _cmd_checkout(args.worktree)
    if args.command == "convert-to-worktree":
        return _cmd_convert_to_worktree(args.worktree, args.base)
    if args.command == "push-force":
        return _cmd_push_force()

    parser.print_help()
    return 2


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except ArborError as exc:
        print(f"error: {exc}", file=sys.stderr)
        raise SystemExit(1)
