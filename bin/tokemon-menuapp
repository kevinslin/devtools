#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
APP_SOURCE="$ROOT_DIR/apps/tokemon/TokemonMenuApp.swift"
TOKEMON_CLI="$ROOT_DIR/bin/tokemon"
OUTPUT_APP="${HOME}/Applications/Tokemon.app"
OPEN_APP=1

usage() {
  cat <<'EOF'
Usage: tokemon-menuapp [--output PATH] [--no-open]

Build a native macOS Tokemon menu-bar app bundle that renders Tokemon usage charts.

Options:
  --output PATH  Write the app bundle to PATH (default: ~/Applications/Tokemon.app)
  --no-open      Build the app but do not launch it after writing the bundle
  -h, --help     Show this help text
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --output)
      if [[ $# -lt 2 ]]; then
        echo "error: --output requires a path" >&2
        exit 2
      fi
      OUTPUT_APP="$2"
      shift 2
      ;;
    --no-open)
      OPEN_APP=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "error: unknown argument '$1'" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if ! command -v swiftc >/dev/null 2>&1; then
  echo "error: swiftc was not found on PATH" >&2
  exit 2
fi

SDK_PATH="$(xcrun --show-sdk-path --sdk macosx)"
APP_CONTENTS="$OUTPUT_APP/Contents"
APP_EXECUTABLE="$APP_CONTENTS/MacOS/Tokemon"
APP_RESOURCES="$APP_CONTENTS/Resources"
APP_BUNDLED_CLI="$APP_RESOURCES/bin/tokemon"

mkdir -p "$(dirname "$OUTPUT_APP")"
rm -rf "$OUTPUT_APP"
mkdir -p "$APP_CONTENTS/MacOS" "$APP_RESOURCES/bin"

cat >"$APP_CONTENTS/Info.plist" <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDisplayName</key>
  <string>Tokemon</string>
  <key>CFBundleExecutable</key>
  <string>Tokemon</string>
  <key>CFBundleIdentifier</key>
  <string>com.kevinlin.devtools.tokemon</string>
  <key>CFBundleName</key>
  <string>Tokemon</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleShortVersionString</key>
  <string>1.0</string>
  <key>CFBundleVersion</key>
  <string>1</string>
  <key>LSMinimumSystemVersion</key>
  <string>13.0</string>
  <key>LSUIElement</key>
  <true/>
  <key>NSHighResolutionCapable</key>
  <true/>
</dict>
</plist>
EOF

swiftc \
  -parse-as-library \
  "$APP_SOURCE" \
  -sdk "$SDK_PATH" \
  -framework SwiftUI \
  -framework AppKit \
  -framework Charts \
  -o "$APP_EXECUTABLE"

cp "$TOKEMON_CLI" "$APP_BUNDLED_CLI"
chmod +x "$APP_EXECUTABLE" "$APP_BUNDLED_CLI"

printf 'Built Tokemon menu app at %s\n' "$OUTPUT_APP"

if [[ "$OPEN_APP" -eq 1 ]]; then
  open "$OUTPUT_APP"
fi
